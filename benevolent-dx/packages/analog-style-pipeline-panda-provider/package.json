{
  "name": "@snyder-tech/bdx-analog-style-pipeline-panda-provider",
  "version": "0.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@snyder-tech/bdx-analog-style-pipeline-core": "workspace:*",
    "valibot": "catalog:"
  },
  "peerDependencies": {
    "@pandacss/dev": "^1.0.0"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint src --deny warnings",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
