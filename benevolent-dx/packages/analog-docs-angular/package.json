{
  "name": "@snyder-tech/bdx-analog-docs-angular",
  "version": "0.0.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@shikijs/rehype": "catalog:",
    "@snyder-tech/bdx-analog-markdown-pipeline": "workspace:*",
    "hast": "catalog:",
    "md4x": "catalog:",
    "rehype-autolink-headings": "catalog:",
    "rehype-slug": "catalog:",
    "rehype-stringify": "catalog:",
    "remark-directive": "catalog:",
    "remark-gfm": "catalog:",
    "remark-parse": "catalog:",
    "remark-rehype": "catalog:",
    "shiki": "catalog:",
    "unified": "catalog:",
    "unist-util-visit": "catalog:"
  },
  "peerDependencies": {
    "@analogjs/content": "^3.0.0-alpha.25",
    "@angular/common": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/router": "^21.0.0"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint src --deny warnings",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/hast": "catalog:",
    "@types/mdast": "catalog:"
  }
}
